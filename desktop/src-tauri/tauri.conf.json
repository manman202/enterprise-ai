{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Aiyedun",
  "version": "1.0.0",
  "identifier": "online.aiyedun.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Aiyedun",
        "width": 420,
        "height": 680,
        "minWidth": 380,
        "minHeight": 500,
        "resizable": true,
        "decorations": true,
        "alwaysOnTop": false,
        "center": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [],
    "externalBin": [],
    "copyright": "Aiyedun",
    "category": "Productivity",
    "shortDescription": "Your institutional memory — always available",
    "longDescription": "Aiyedun is your company AI knowledge assistant. Ask questions, get answers from your company documents."
  }
}
